{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build PDF (latexmk)",
			"type": "shell",
			"command": "latexmk",
			"args": [
				"-pdf",
				"-synctex=1",
				"-interaction=nonstopmode",
				"-file-line-error",
				"-recorder",
				"thesis.tex"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Clean Aux (latexmk -c)",
			"type": "shell",
			"command": "latexmk",
			"args": [
				"-c",
				"thesis.tex"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Clean + Build PDF (latexmk)",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"latexmk -C thesis.tex && latexmk -pdf -synctex=1 -interaction=nonstopmode -file-line-error -recorder thesis.tex"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Watch PDF (latexmk -pvc)",
			"type": "shell",
			"command": "latexmk",
			"args": [
				"-pdf",
				"-synctex=1",
				"-interaction=nonstopmode",
				"-file-line-error",
				"-recorder",
				"-pvc",
				"thesis.tex"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}